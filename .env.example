NODE_ENV=development
LOG_LEVEL=info

# Database
DATABASE_URL=postgres://multiuser:multiuser@localhost:5432/multiuser

# Model providers — configure whichever your agent definitions reference
OPENROUTER_API_KEY=
ANTHROPIC_API_KEY=
OPENAI_API_KEY=

# Optional local/OpenAI-compatible provider. When LOCAL_MODEL_BASE_URL is set,
# DEFAULT_MODEL_SPEC can use "local:<model-id>" (or change LOCAL_MODEL_PROVIDER).
# Examples:
#   LOCAL_MODEL_BASE_URL=http://localhost:11434/v1
#   DEFAULT_MODEL_SPEC=local:llama3.1:8b
#   LOCAL_MODEL_API_KEY=dummy
LOCAL_MODEL_PROVIDER=local
LOCAL_MODEL_BASE_URL=
LOCAL_MODEL_API_KEY=dummy
LOCAL_MODEL_CONTEXT_WINDOW=131072
LOCAL_MODEL_MAX_TOKENS=8192
LOCAL_MODEL_REASONING=0

# Agent definitions pick their own model via "<provider>:<slug>" specs.
# Examples:
#   openrouter:qwen/qwen-2.5-72b-instruct
#   openrouter:minimax/minimax-01
#   anthropic:claude-sonnet-4-6
#   anthropic:claude-opus-4-6   (long-context reviewer)
#   openai:gpt-4o-mini
#   local:llama3.1:8b                  (OpenAI-compatible local server)

# Embeddings
EMBED_MODEL=text-embedding-3-small
EMBED_DIM=1536

# Discord (unused in skeleton)
DISCORD_BOT_TOKEN=
DISCORD_APPLICATION_ID=
DISCORD_TEST_INVITE_URL=

# Default model used by CLI live-responder
DEFAULT_MODEL_SPEC=openrouter:minimax/minimax-m2.7

# Optional runtime logging flags (0/1)
LOG_DB_NOTICES=0
LOG_LLM_INPUT=0
