NODE_ENV=development
LOG_LEVEL=info

# Database
DATABASE_URL=postgres://multiuser:multiuser@localhost:5432/multiuser

# Model providers — any one required depending on chosen defaults
OPENROUTER_API_KEY=
ANTHROPIC_API_KEY=
OPENAI_API_KEY=

# Model slugs — update to current availability on chosen provider
MODEL_CHEAP_PROVIDER=openrouter
MODEL_CHEAP=qwen/qwen-2.5-72b-instruct
MODEL_PREMIUM_PROVIDER=openrouter
MODEL_PREMIUM=qwen/qwen3-max

# Testing fallbacks
MODEL_TEST_PROVIDER=anthropic
MODEL_TEST=claude-sonnet-4-6

# Embeddings
EMBED_PROVIDER=openai
EMBED_MODEL=text-embedding-3-small
EMBED_DIM=1536

# Discord (unused in skeleton)
DISCORD_BOT_TOKEN=
DISCORD_APPLICATION_ID=
