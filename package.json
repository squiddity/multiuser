{
  "name": "multiuser",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "description": "Multi-user, multi-room agent-driven shared fiction platform (Discord-first)",
  "scripts": {
    "dev": "tsx watch src/cli/harness.ts",
    "serve": "tsx watch src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "test": "vitest run test/unit test/smoke.test.ts",
    "test:integration": "vitest run test/integration --no-file-parallelism",
    "test:ci": "pnpm typecheck && pnpm test",
    "test:watch": "vitest",
    "test:api": "bash scripts/api-test.sh",
    "db:generate": "drizzle-kit generate",
    "db:push": "drizzle-kit push",
    "db:migrate": "drizzle-kit migrate",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@ai-sdk/anthropic": "^1.1.0",
    "@ai-sdk/openai": "^1.1.0",
    "@hono/node-server": "^1.19.14",
    "@mastra/core": "^0.10.0",
    "@openrouter/ai-sdk-provider": "^0.4.0",
    "ai": "^4.1.0",
    "croner": "^9.0.0",
    "discord.js": "^14.16.3",
    "dotenv": "^16.4.7",
    "drizzle-orm": "^0.38.0",
    "hono": "^4.0.0",
    "pgvector": "^0.2.0",
    "pino": "^9.5.0",
    "pino-pretty": "^13.0.0",
    "postgres": "^3.4.5",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@types/node": "^22.10.0",
    "drizzle-kit": "^0.30.0",
    "prettier": "^3.4.0",
    "tsx": "^4.19.2",
    "typescript": "^5.7.0",
    "vitest": "^2.1.0"
  },
  "engines": {
    "node": ">=20"
  },
  "packageManager": "pnpm@9.15.0"
}
